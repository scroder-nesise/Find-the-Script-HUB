-- Safe character/root getter — returns HumanoidRootPart or nil

local function getRoot()

   local char = player.Character

   return char and char:FindFirstChild("HumanoidRootPart")

end



-- Add a BasePart to an object map with a deduplicated label, and push to options table

local function registerObj(map, options, obj)

   local base = obj.Name

   local label = base

   local i = 1

   while map[label] do

      i = i + 1

      label = base .. " (" .. i .. ")"

   end

   map[label] = obj

   table.insert(options, label)

end



-- Generic deep scanner: finds all BaseParts related to a keyword

local function scanForKeyword(keyword)

   local map = {}

   local options = {}

   local seen = {} -- track by object identity to avoid double-adding



   for _, obj in pairs(workspace:GetDescendants()) do

      local nameLower = string.lower(obj.Name)



      -- BasePart directly named with keyword

      if obj:IsA("BasePart") and string.find(nameLower, keyword) then

         if not seen[obj] then

            seen[obj] = true

            registerObj(map, options, obj)

         end



      -- Model or Folder named with keyword → grab its root BasePart

      elseif (obj:IsA("Model") or obj:IsA("Folder")) and string.find(nameLower, keyword) then

         local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart", true)

         if part and not seen[part] then

            seen[part] = true

            registerObj(map, options, part)

         end



      -- BasePart whose parent container is named with keyword

      elseif obj:IsA("BasePart") and obj.Parent

         and string.find(string.lower(obj.Parent.Name), keyword) then

         if not seen[obj] then

            seen[obj] = true

            registerObj(map, options, obj)

         end



      -- TouchTransmitter whose parent BasePart is named with keyword

      elseif obj:IsA("TouchTransmitter") then

         local part = obj.Parent

         if part and part:IsA("BasePart")

            and string.find(string.lower(part.Name), keyword)

            and not seen[part] then

            seen[part] = true

            registerObj(map, options, part)

         end

      end

   end



   return map, options

end



