-- Safe character/root getter — returns HumanoidRootPart or nil
local function getRoot()
   local char = player.Character
   return char and char:FindFirstChild("HumanoidRootPart")
end


-- Add a BasePart to an object map with a deduplicated label, and push to options table
local function registerObj(map, options, obj)
   local base = obj.Name
   local label = base
   local i = 1
   while map[label] do
      i = i + 1
      label = base .. " (" .. i .. ")"
   end
   map[label] = obj
   table.insert(options, label)
end


-- Multi-keyword deep scanner: finds all BaseParts matching ANY of the given keywords
local function scanForKeywords(keywords)
   local map = {}
   local options = {}
   local seen = {} -- track by object identity to avoid double-adding

   local function matchesAny(name)
      local nameLower = string.lower(name)
      for _, kw in ipairs(keywords) do
         if string.find(nameLower, kw, 1, true) then
            return true
         end
      end
      return false
   end

   for _, obj in pairs(workspace:GetDescendants()) do

      -- BasePart directly named with any keyword
      if obj:IsA("BasePart") and matchesAny(obj.Name) then
         if not seen[obj] then
            seen[obj] = true
            registerObj(map, options, obj)
         end

      -- Model or Folder named with any keyword → grab its root BasePart
      elseif (obj:IsA("Model") or obj:IsA("Folder")) and matchesAny(obj.Name) then
         local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart", true)
         if part and not seen[part] then
            seen[part] = true
            registerObj(map, options, part)
         end

      -- BasePart whose parent container is named with any keyword
      elseif obj:IsA("BasePart") and obj.Parent
         and matchesAny(obj.Parent.Name) then
         if not seen[obj] then
            seen[obj] = true
            registerObj(map, options, obj)
         end

      -- TouchTransmitter whose parent BasePart is named with any keyword
      elseif obj:IsA("TouchTransmitter") then
         local part = obj.Parent
         if part and part:IsA("BasePart")
            and matchesAny(part.Name)
            and not seen[part] then
            seen[part] = true
            registerObj(map, options, part)
         end
      end
   end

   return map, options
end


